# Database
POSTGRES_USER=memoria
POSTGRES_PASSWORD=memoria_dev_password
POSTGRES_DB=memoria
DATABASE_URL=postgresql://memoria:memoria_dev_password@postgres:5432/memoria

# JWT Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Speech
ELEVENLABS_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Email (SendGrid)
SENDGRID_API_KEY=
